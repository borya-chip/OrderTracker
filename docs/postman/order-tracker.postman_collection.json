    {
      "name": "Order Transaction Scenario",
      "item": [
        {
          "name": "Run Scenario (NoTx, Fail After Meals)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": {{customerId}},\n  \"categoryId\": {{categoryId}},\n  \"restaurantId\": {{restaurantId}},\n  \"amount\": 18.90,\n  \"orderedAt\": \"2026-03-11T14:00:00\",\n  \"description\": \"NoTx check\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/transaction?transactional=false&failAfterMealsSave=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "transaction"
              ],
              "query": [
                {
                  "key": "transactional",
                  "value": "false"
                },
                {
                  "key": "failAfterMealsSave",
                  "value": "true"
                }
              ]
            }
          }
        },
